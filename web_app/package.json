{
  "name": "web_app",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "main": "main.js",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "electron:dev": "electron .",
    "electron:build": "vite build && electron-builder",
    "package-win": "npx @electron/packager . OmniNotes-Stark --platform=win32 --arch=x64 --out=dist_pc --overwrite --ignore=\"^/src\" --ignore=\"^/node_modules\" --ignore=\"^/dist_electron\" --ignore=\"/\\.git\""
  },
  "dependencies": {
    "@types/prismjs": "^1.26.6",
    "@types/qrcode.react": "^1.0.5",
    "@vitejs/plugin-react": "^6.0.0",
    "framer-motion": "^12.36.0",
    "gapi-script": "^1.2.0",
    "lucide-react": "^0.577.0",
    "prismjs": "^1.30.0",
    "qrcode.react": "^4.2.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-masonry-css": "^1.0.16",
    "react-quill": "^2.0.0",
    "socket.io-client": "^4.8.3",
    "vite": "^8.0.0"
  },
  "devDependencies": {
    "@electron/packager": "^19.1.0",
    "@eslint/js": "^9.39.4",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.0",
    "electron": "^41.0.2",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "build": {
    "appId": "com.ignisight.omninotes",
    "productName": "OmniNotes-Stark",
    "directories": {
      "output": "dist_electron"
    },
    "files": [
      "dist/**/*",
      "main.js",
      "preload.js",
      "package.json"
    ],
    "win": {
      "target": "portable"
    }
  }
}
